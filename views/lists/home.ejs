<% layout('layouts/boilerplate') %>

<div class="landing-wrapper">
    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>
    <div class="ambient-orb orb-3"></div>

    <div class="container d-flex flex-column align-items-center justify-content-center text-center hero-section">
        
        <div class="hero-content hero-glass-panel">
            <div class="badge-container mb-4">
                <span class="badge-new shadow-sm">
                    <i class="fa-solid fa-house-user"></i> Welcome to Basera
                </span>
            </div>
            
            <h1 class="hero-title">
                Find Your Next <br>
                <span class="text-highlight animate-gradient">Perfect Gateway</span>
            </h1>
            
            <p class="hero-subtitle mt-4 mb-5">
                Discover unique homes, breathtaking experiences, and places around the world to call yours for the weekend.
            </p>

            <div class="hero-actions d-flex gap-4 justify-content-center flex-wrap">
                <a href="/listings" class="btn btn-hero-primary shadow-lg">
                    <i class="fa-solid fa-compass me-2"></i> Explore Listings
                </a>
                <a href="/listings/new" class="btn btn-hero-secondary shadow-sm">
                    <i class="fa-solid fa-house-user me-2"></i> Host a Home
                </a>
            </div>
        </div>

    </div>
</div>