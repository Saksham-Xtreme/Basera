<% layout("/layouts/boilerplate") %>

<div class="create-listing">
    <h2>Create New Listing</h2>

    <form method="POST" action="/listings" novalidate class="needs-validation">

        <div class="form-group">
            <label class="form-label">Title</label>
            <input 
                name="listing[title]" 
                class="form-control" 
                type="text" 
                placeholder="Enter title" 
                required
            >
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Please enter a valid title.</div>
        </div>

        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea 
                name="listing[description]" 
                class="form-control" 
                placeholder="Enter description" 
                required
            ></textarea>
            <div class="valid-feedback">Nice description.</div>
            <div class="invalid-feedback">Description is required.</div>
        </div>

        <div class="form-group">
            <label class="form-label">Image URL</label>
            <input 
                name="listing[image][url]" 
                class="form-control" 
                type="text" 
                required
            >
            <div class="valid-feedback">Image looks good.</div>
            <div class="invalid-feedback">Please provide an image URL.</div>
        </div>

        <div class="form-group">
            <label class="form-label">Country</label>
            <input 
                name="listing[country]" 
                class="form-control" 
                type="text" 
                required
            >
            <div class="valid-feedback">Country added.</div>
            <div class="invalid-feedback">Country is required.</div>
        </div>

        <div class="form-group">
            <label class="form-label">Location</label>
            <input 
                name="listing[location]" 
                class="form-control" 
                type="text" 
                required
            >
            <div class="valid-feedback">Location looks good.</div>
            <div class="invalid-feedback">Please enter a location.</div>
        </div>

        <div class="form-group">
            <label class="form-label">Price</label>
            <input 
                name="listing[price]" 
                class="form-control" 
                type="number" 
                required
                min="1"
            >
            <div class="valid-feedback">Price looks fine.</div>
            <div class="invalid-feedback">Please enter a valid price.</div>
        </div>

        <button class="btn-submit">Add Listing</button>
    </form>
</div>
