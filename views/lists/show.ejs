<% layout("/layouts/boilerplate") %>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow-sm border-0 rounded-4 listing-detail">

                <!-- Image -->
                <img 
                    src="<%= listing.image.url %>" 
                    class="card-img-top rounded-top-4" 
                    alt="listing image"
                >

                <div class="card-body p-4">

                    <h3 class="card-title mb-3"><%= listing.title %></h3>

                    <div class="listing-owner">
                        <div class="owner-avatar">
                            <%= listing.owner.username.charAt(0).toUpperCase() %>
                        </div>
                    
                        <div class="owner-info">
                            <span class="owner-label">Owned by</span>
                            <span class="owner-name"><%= listing.owner.username %></span>
                        </div>
                    </div>

                    <p class="text-muted mb-3">
                        <%= listing.description %>
                    </p>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item">
                            <strong>Price:</strong>
                            ₹ <%= listing.price.toLocaleString("en-IN") %> / night
                        </li>
                        <li class="list-group-item">
                            <strong>Country:</strong> <%= listing.country %>
                        </li>
                        <li class="list-group-item">
                            <strong>Location:</strong> <%= listing.location %>
                        </li>
                    </ul>

                    <% if(currentUser && listing.owner._id.equals(currentUser._id)){ %>
                    <!-- ACTION BUTTONS -->
                        <div class="d-flex gap-2">

                            <!-- EDIT -->
                            <a 
                                href="/listings/<%= listing._id %>/edit" 
                                class="btn btn-outline-secondary w-100"
                            >
                                Edit Listing
                            </a>

                            <!-- DELETE -->
                            <form 
                                method="POST" 
                                action="/listings/<%= listing._id %>?_method=DELETE"
                                class="w-100"
                            >
                                <button class="btn btn-outline-danger w-100">
                                    Delete Listing
                                </button>
                            </form>

                        </div>

                    <% } %>

                </div>
            </div>

            <% if(currentUser){ %>
            <div class="review-section mt-5">

                <h4 class="mb-4">Leave a Review</h4>
            
                <form 
                    method="POST" 
                    action="/listings/<%= listing._id %>/reviews" 
                    novalidate 
                    class="needs-validation"
                >
            
                    <!-- Rating -->
                    <div class="mb-3">
                        <label class="form-label">
                            Rating: <span id="rating-value">3</span>
                        </label>
                    
                        <input 
                            type="range" 
                            min="1" 
                            max="5" 
                            value="3"
                            name="review[rating]" 
                            class="form-range"
                            id="rating-slider"
                            required
                        >
                    
                        <div class="invalid-feedback">
                            Please select a rating.
                        </div>
                    </div>
            
                    <!-- Comment -->
                    <div class="mb-3">
                        <label class="form-label">Comment</label>
                        <textarea 
                            name="review[comment]" 
                            class="form-control" 
                            rows="3"
                            required
                        ></textarea>
                        <div class="invalid-feedback">
                            Please write a review comment.
                        </div>
                    </div>
            
                    <button class="btn btn-primary rounded-pill px-4">
                        Submit Review
                    </button>
            
                </form>

                <% } else { %>

                    <p class="text-muted mt-4">
                      Please <a href="/login">log in</a> to leave a review.
                    </p>
                    
                <% } %>
            
                <hr class="my-5">
            
                
            
                <hr class="my-5">

                <h4 class="mb-4 fw-semibold">All Reviews</h4>

                <div class="reviews-grid">

                    <% for (let review of listing.reviews) { %>

                        <div class="review-card">

                            <!-- Header -->
                            <div class="review-header">

                                <div class="review-avatar">
                                    <%= review.author.username.charAt(0).toUpperCase() %>
                                </div>

                                <div class="review-user-info">
                                    <h6 class="review-name">
                                        <%= review.author ? review.author.username : "Guest" %>
                                    </h6>
                                    <small class="review-meta">
                                        <%= review.createdAt.toDateString() %>
                                    </small>
                                </div>

                            </div>

                            <!-- Rating -->
                            <div class="review-rating">
                                <% for(let i=0; i<review.rating; i++){ %>
                                    ⭐
                                <% } %>
                            </div>

                            <!-- Comment -->
                            <p class="review-text">
                                <%= review.comment %>
                            </p>
                            
                            <% if(currentUser && review.author && review.author._id.toString() === currentUser._id.toString()){ %>
                            <div class="review-actions">
                                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="review-delete">Delete</button>
                                </form>
                            </div>

                            <% }  %>
                             

                        </div>

                    <% } %>

                </div>


        </div>
    </div>
</div>